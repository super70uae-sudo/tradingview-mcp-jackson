//@version=6
indicator("Supply and Demand Entry Zones", overlay=true, scale=scale.none, max_boxes_count=10)

baseBars = input.int(3, "Base candles", minval=1, maxval=10)
atrLength = input.int(14, "ATR length", minval=1)
impulseAtr = input.float(1.5, "Impulse size in ATR", minval=0.25, step=0.25)
maxBaseAtr = input.float(1.2, "Maximum base height in ATR", minval=0.25, step=0.25)
showDemand = input.bool(true, "Show demand zone")
showSupply = input.bool(true, "Show supply zone")

plot(na, title="Study Anchor", display=display.none)

atr = ta.atr(atrLength)
baseHigh = ta.highest(high[1], baseBars)
baseLow = ta.lowest(low[1], baseBars)
baseHeight = baseHigh - baseLow

body = math.abs(close - open)
bullImpulse = close > baseHigh and close > open and body >= atr * impulseAtr and baseHeight <= atr * maxBaseAtr
bearImpulse = close < baseLow and close < open and body >= atr * impulseAtr and baseHeight <= atr * maxBaseAtr

var float demandTop = na
var float demandBottom = na
var int demandStartTime = na
var bool demandActive = false
var box demandBox = na

var float supplyTop = na
var float supplyBottom = na
var int supplyStartTime = na
var bool supplyActive = false
var box supplyBox = na

deleteBox(box b) =>
    if not na(b)
        box.delete(b)

if bullImpulse
    deleteBox(demandBox)
    demandTop := baseHigh
    demandBottom := baseLow
    demandStartTime := time[baseBars]
    demandActive := true
    demandBox := showDemand ? box.new(demandStartTime, demandTop, time, demandBottom, xloc=xloc.bar_time, extend=extend.right, bgcolor=color.new(color.lime, 84), border_color=color.new(color.lime, 20)) : na

if bearImpulse
    deleteBox(supplyBox)
    supplyTop := baseHigh
    supplyBottom := baseLow
    supplyStartTime := time[baseBars]
    supplyActive := true
    supplyBox := showSupply ? box.new(supplyStartTime, supplyTop, time, supplyBottom, xloc=xloc.bar_time, extend=extend.right, bgcolor=color.new(color.red, 84), border_color=color.new(color.red, 20)) : na

if demandActive and close < demandBottom
    demandActive := false
    deleteBox(demandBox)
    demandBox := na

if supplyActive and close > supplyTop
    supplyActive := false
    deleteBox(supplyBox)
    supplyBox := na

if demandActive and not na(demandBox)
    box.set_top(demandBox, demandTop)
    box.set_bottom(demandBox, demandBottom)
    box.set_left(demandBox, demandStartTime)
    box.set_right(demandBox, time)

if supplyActive and not na(supplyBox)
    box.set_top(supplyBox, supplyTop)
    box.set_bottom(supplyBox, supplyBottom)
    box.set_left(supplyBox, supplyStartTime)
    box.set_right(supplyBox, time)
